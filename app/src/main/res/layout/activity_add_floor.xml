<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <EditText
        android:id="@+id/txtWidth"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Width (mm)"
        android:inputType="numberDecimal" />

    <EditText
        android:id="@+id/txtDepth"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Depth (mm)"
        android:inputType="numberDecimal" />

    <EditText
        android:id="@+id/txtNotes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Notes"
        android:inputType="text" />

    <Button
        android:id="@+id/btnSaveFloor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Save Floor" />

    <Button
        android:id="@+id/btnDeleteFloor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Delete Floor" />

    <Button
        android:id="@+id/btnChooseProduct"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Choose Product" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Choose Colour"
        android:textSize="16sp"
        android:layout_marginTop="12dp" />

    <Spinner
        android:id="@+id/spinnerColour"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="4dp"
        android:background="@android:drawable/btn_dropdown"
        android:padding="12dp" />

</LinearLayout>