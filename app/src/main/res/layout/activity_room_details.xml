<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".RoomDetailsActivity">

    <Button
        android:id="@+id/btnAddFloor"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add Floor Space"
        tools:layout_editor_absoluteX="178dp"
        tools:layout_editor_absoluteY="273dp" />

    <Button
        android:id="@+id/btnAddWindows"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add Window"
        tools:layout_editor_absoluteX="184dp"
        tools:layout_editor_absoluteY="369dp" />

    <Button
        android:id="@+id/btnQuote"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Quote"
        tools:layout_editor_absoluteX="210dp"
        tools:layout_editor_absoluteY="151dp" />

    <TextView
        android:id="@+id/lblFloorSpaces"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Floor Spaces"
        tools:layout_editor_absoluteX="112dp"
        tools:layout_editor_absoluteY="95dp" />

    <TextView
        android:id="@+id/lblWindows"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Windows"
        tools:layout_editor_absoluteX="238dp"
        tools:layout_editor_absoluteY="44dp" />
</androidx.constraintlayout.widget.ConstraintLayout>