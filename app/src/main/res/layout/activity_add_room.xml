<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <EditText
        android:id="@+id/txtRoomName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Room Name"
        android:inputType="text" />

    <EditText
        android:id="@+id/txtRoomWidth"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Width (mm)"
        android:inputType="numberDecimal" />

    <EditText
        android:id="@+id/txtRoomDepth"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Depth (mm)"
        android:inputType="numberDecimal" />

    <Button
        android:id="@+id/btnSaveRoom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Save Room" />

    <Button
        android:id="@+id/btnDeleteRoom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Delete Room" />

</LinearLayout>